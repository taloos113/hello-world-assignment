{
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "src/HelloWorld.Console/bin/Release/net8.0/HelloWorld.Console.dll"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
